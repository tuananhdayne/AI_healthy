# Example environment variables required to run the project
# Rename to .env and fill values (do NOT commit secrets)

# Path to service account JSON (if used locally)
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# FAISS index directory or file
FAISS_INDEX_DIR=embeddings/

# Firebase project id (if using Firebase)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# App settings
PORT=8000
DEBUG=true
